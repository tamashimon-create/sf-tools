#!/bin/bash

# ==============================================================================
# hooks/precommit - precommit フック本体
# ==============================================================================
# このスクリプトは sf-hook.sh からコピーされて使用されます。
# 設置場所例: ~/sf-tools/hooks/precommit
# ==============================================================================

# Generated by sf-tools: wrapper for pre-push hook

readonly SCRIPT_PATH="$HOME/sf-tools/sf-precommit.sh"

if [[ ! -f "$SCRIPT_PATH" ]]; then
    echo "[PRE-PUSH][ERROR] スクリプトが見つかりません: $SCRIPT_PATH" >&2
    exit 1
fi

"$SCRIPT_PATH" --verbose
exit $?
