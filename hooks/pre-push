#!/bin/bash

# ==============================================================================
# hooks/pre-push - pre-push フック実体
# ==============================================================================
# このスクリプトは sf-hook.sh が生成するラッパーから呼び出されます。
# 設置場所: ~/sf-tools/hooks/pre-push
# ==============================================================================

readonly SCRIPT_PATH="$HOME/sf-tools/sf-push.sh"

if [[ ! -f "$SCRIPT_PATH" ]]; then
    echo "[PRE-PUSH][ERROR] ツールが見つかりません: $SCRIPT_PATH" >&2
    exit 1
fi

"$SCRIPT_PATH" --verbose
exit $?
